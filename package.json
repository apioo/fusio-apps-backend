    "ngx-gravatar": "^13.0.0",
    "ngx-highlightjs": "^12.0.0",
    "ngx-markdown": "^21.1.0",
    "ngx-monaco-editor-v2-alternative": "^21.0.1",
    "ngx-typeschema-editor": "^5.0.0",
    "rxjs": "~7.8.0",
    "sdkgen-client": "^2.1.0",
    "tslib": "^2.3.0",
    "typehub-javascript-sdk": "^1.2.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "jsdom": "^27.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
